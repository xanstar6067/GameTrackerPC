<Window x:Class="GameTrackerPC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:GameTrackerPC.Models"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        mc:Ignorable="d"
        Title="Reliquary"
        Height="840"
        Width="1280"
        MinHeight="680"
        MinWidth="760"
        Loaded="Window_Loaded"
        Background="{DynamicResource AppBackgroundBrush}"
        FontSize="{DynamicResource AppBodyFontSize}">
    <Window.Resources>
        <sys:Double x:Key="AppBodyFontSize">14</sys:Double>
        <sys:Double x:Key="AppSmallFontSize">11</sys:Double>
        <sys:Double x:Key="AppLabelFontSize">12</sys:Double>
        <sys:Double x:Key="AppMutedFontSize">13</sys:Double>
        <sys:Double x:Key="AppLargeFontSize">18</sys:Double>
        <sys:Double x:Key="AppScreenTitleFontSize">20</sys:Double>
        <sys:Double x:Key="AppSectionTitleFontSize">22</sys:Double>
        <sys:Double x:Key="AppMenuButtonFontSize">24</sys:Double>
        <sys:Double x:Key="AppDetailTitleFontSize">34</sys:Double>
        <sys:Double x:Key="AppHeroFontSize">68</sys:Double>
        <sys:Double x:Key="AppControlMinHeight">38</sys:Double>
        <sys:Double x:Key="AppHeaderControlHeight">36</sys:Double>
        <sys:Double x:Key="AppStartButtonHeight">48</sys:Double>
        <sys:Double x:Key="AppColorSwatchWidth">38</sys:Double>
        <sys:Double x:Key="AppScaleStepButtonWidth">42</sys:Double>
        <sys:Double x:Key="AppScaleValueColumnWidth">76</sys:Double>
        <sys:Double x:Key="AppFontScaleGridWidth">620</sys:Double>
        <sys:Double x:Key="AppCardScaleControlFontSize">13</sys:Double>
        <Thickness x:Key="AppButtonPadding">16,9</Thickness>
        <Thickness x:Key="AppHeaderButtonPadding">14,0</Thickness>
        <Thickness x:Key="AppInputPadding">10,6</Thickness>
        <Thickness x:Key="AppComboBoxPadding">8,5</Thickness>
        <Thickness x:Key="AppComboBoxItemPadding">10,7</Thickness>

        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#08111F" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#101B2D" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#17243A" />
        <SolidColorBrush x:Key="PanelBrush" Color="#0B1424" />
        <SolidColorBrush x:Key="TextBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9BA8BC" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#38516E" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#38F2C2" />
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#73FFE0" />
        <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#1BB893" />
        <SolidColorBrush x:Key="SecondaryBrush" Color="#FFCC33" />
        <SolidColorBrush x:Key="ButtonTextBrush" Color="#061019" />
        <SolidColorBrush x:Key="DangerBrush" Color="#FF4D6D" />
        <SolidColorBrush x:Key="ExitIdleBrush" Color="#95FFFF" />
        <SolidColorBrush x:Key="ExitHoverBrush" Color="#E5242A" />
        <SolidColorBrush x:Key="InputBrush" Color="#0E1A2C" />
        <SolidColorBrush x:Key="InputTextBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="ChipBrush" Color="#163D48" />
        <SolidColorBrush x:Key="GameCardBrush" Color="#132034" />
        <SolidColorBrush x:Key="GameCardHoverBrush" Color="#162A3A" />

        <Style x:Key="CyberButton" TargetType="{x:Type Button}">
            <Setter Property="Padding" Value="{DynamicResource AppButtonPadding}" />
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="MinHeight" Value="{DynamicResource AppControlMinHeight}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource ButtonTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, Segoe UI" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="Chrome"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" />
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource PrimaryHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource PrimaryPressedBrush}" />
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform X="1" Y="1" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource CyberButton}" />

        <Style x:Key="SecondaryButton" TargetType="{x:Type Button}" BasedOn="{StaticResource CyberButton}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
        </Style>

        <Style x:Key="DangerButton" TargetType="{x:Type Button}" BasedOn="{StaticResource CyberButton}">
            <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="ExitButton" TargetType="{x:Type Button}" BasedOn="{StaticResource CyberButton}">
            <Setter Property="Background" Value="{DynamicResource ExitIdleBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ExitIdleBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="Chrome"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" />
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource ExitHoverBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource ExitHoverBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource ExitHoverBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource ExitHoverBrush}" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform X="1" Y="1" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderButton" TargetType="{x:Type Button}" BasedOn="{StaticResource CyberButton}">
            <Setter Property="Height" Value="{DynamicResource AppHeaderControlHeight}" />
            <Setter Property="MinHeight" Value="{DynamicResource AppHeaderControlHeight}" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="{DynamicResource AppHeaderButtonPadding}" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="HeaderSecondaryButton" TargetType="{x:Type Button}" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Height" Value="{DynamicResource AppHeaderControlHeight}" />
            <Setter Property="MinHeight" Value="{DynamicResource AppHeaderControlHeight}" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="{DynamicResource AppHeaderButtonPadding}" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="ColorSwatchButton" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="{DynamicResource AppColorSwatchWidth}" />
            <Setter Property="Height" Value="{DynamicResource AppHeaderControlHeight}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform X="1" Y="1" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="MinHeight" Value="{DynamicResource AppHeaderControlHeight}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="{DynamicResource AppInputPadding}" />
            <Setter Property="Margin" Value="0,4,0,12" />
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource InputTextBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Grid>
                            <Border x:Name="Chrome"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" />
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter Property="Opacity" Value="0.72" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderTextBox" TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Height" Value="{DynamicResource AppHeaderControlHeight}" />
            <Setter Property="MinHeight" Value="{DynamicResource AppHeaderControlHeight}" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="MinHeight" Value="{DynamicResource AppHeaderControlHeight}" />
            <Setter Property="Margin" Value="0,4,0,12" />
            <Setter Property="Padding" Value="{DynamicResource AppComboBoxPadding}" />
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource InputTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Border x:Name="Chrome"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    IsHitTestVisible="False" />
                            <ContentPresenter x:Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="10,0,34,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              IsHitTestVisible="False" />
                            <Path Data="M 0 0 L 5 5 L 10 0"
                                  Stroke="{DynamicResource PrimaryBrush}"
                                  StrokeThickness="2"
                                  Width="10"
                                  Height="6"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Margin="0,0,12,0"
                                  IsHitTestVisible="False" />
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Grid MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrushSoft}"
                                            BorderThickness="1">
                                        <ScrollViewer CanContentScroll="True">
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderComboBox" TargetType="{x:Type ComboBox}" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Height" Value="{DynamicResource AppHeaderControlHeight}" />
            <Setter Property="MinHeight" Value="{DynamicResource AppHeaderControlHeight}" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Padding" Value="{DynamicResource AppComboBoxItemPadding}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource ButtonTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource ChipBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Margin" Value="0,0,12,10" />
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, Segoe UI" />
        </Style>

        <Style TargetType="{x:Type RadioButton}">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Margin" Value="0,0,14,8" />
        </Style>

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>

        <Style x:Key="MutedText" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="{DynamicResource AppMutedFontSize}" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="FontSize" Value="{DynamicResource AppSectionTitleFontSize}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, Segoe UI" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style x:Key="LabelText" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, Segoe UI" />
            <Setter Property="FontSize" Value="{DynamicResource AppLabelFontSize}" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>

        <Style x:Key="CyberPanel" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style x:Key="CyberChip" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource ChipBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
        </Style>

        <Style TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>

        <Style TargetType="{x:Type ListBoxItem}">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="Transparent" />
                                <Setter TargetName="Chrome" Property="Background" Value="Transparent" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="Transparent" />
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource ChipBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CyberDataGridColumnHeader" TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="CyberDataGridCell" TargetType="{x:Type DataGridCell}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="8,5" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ChipBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CyberDataGridRow" TargetType="{x:Type DataGridRow}">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ChipBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="RowBackground" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="ColumnHeaderStyle" Value="{StaticResource CyberDataGridColumnHeader}" />
            <Setter Property="CellStyle" Value="{StaticResource CyberDataGridCell}" />
            <Setter Property="RowStyle" Value="{StaticResource CyberDataGridRow}" />
        </Style>

        <DataTemplate x:Key="GameCardTemplate" DataType="{x:Type models:GameListItem}">
            <Border x:Name="CardChrome"
                    BorderThickness="0"
                    Height="{DynamicResource GameCardHeight}"
                    Padding="{DynamicResource GameCardPadding}"
                    Margin="{DynamicResource GameCardMargin}"
                    Background="{DynamicResource GameCardBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid Width="{DynamicResource GameCardCoverWidth}"
                          Height="{DynamicResource GameCardCoverHeight}"
                          VerticalAlignment="Top"
                          Background="{DynamicResource SurfaceAltBrush}"
                          ClipToBounds="True">
                        <Image Source="{Binding CoverPreview}"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Stretch="Fill" />
                    </Grid>
                    <StackPanel Grid.Column="1"
                                Margin="{DynamicResource GameCardContentMargin}">
                        <TextBlock Text="{Binding Title}"
                                   FontWeight="Bold"
                                   FontSize="{DynamicResource GameCardTitleFontSize}"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap" />
                        <TextBlock Text="{Binding Subtitle}"
                                   Style="{StaticResource MutedText}"
                                   FontSize="{DynamicResource GameCardSmallFontSize}"
                                   Margin="{DynamicResource GameCardSubtitleMargin}"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap" />
                        <Border Style="{StaticResource CyberChip}"
                                HorizontalAlignment="Left"
                                Margin="{DynamicResource GameCardChipMargin}">
                            <TextBlock Text="{Binding Statuses}"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       FontSize="{DynamicResource GameCardSmallFontSize}"
                                       FontFamily="Consolas, Cascadia Mono, Segoe UI"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap" />
                        </Border>
                        <TextBlock Text="{Binding UpdatedText}"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="{DynamicResource GameCardSmallFontSize}"
                                   Margin="{DynamicResource GameCardUpdatedMargin}"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap" />
                    </StackPanel>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" Value="True">
                    <Setter TargetName="CardChrome" Property="Background" Value="{DynamicResource GameCardHoverBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" Value="True">
                    <Setter TargetName="CardChrome" Property="Background" Value="{DynamicResource ChipBrush}" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <ItemsPanelTemplate x:Key="ListPanelTemplate">
            <VirtualizingStackPanel />
        </ItemsPanelTemplate>
        <ItemsPanelTemplate x:Key="TilePanelTemplate">
            <WrapPanel IsItemsHost="True" />
        </ItemsPanelTemplate>

        <Style x:Key="CardScaleSliderStyle" TargetType="{x:Type Slider}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid Width="{TemplateBinding Width}">
                            <Border Width="2"
                                    Margin="0,6"
                                    HorizontalAlignment="Center"
                                    Background="{DynamicResource BorderBrushSoft}" />
                            <Track x:Name="PART_Track"
                                   Width="24"
                                   HorizontalAlignment="Center"
                                   Orientation="{TemplateBinding Orientation}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge"
                                                  Opacity="0"
                                                  Focusable="False" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="18"
                                           Height="10"
                                           Focusable="False">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border Background="{DynamicResource SurfaceBrush}"
                                                        BorderBrush="{DynamicResource BorderBrushSoft}"
                                                        BorderThickness="1" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge"
                                                  Opacity="0"
                                                  Focusable="False" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootShell">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal">
                    <Button x:Name="BackButton"
                            Content="Back"
                            Style="{StaticResource SecondaryButton}"
                            Click="BackButton_Click" />
                    <Button x:Name="HomeButton"
                            Content="Home"
                            Style="{StaticResource SecondaryButton}"
                            Click="HomeButton_Click" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <ProgressBar x:Name="DownloadProgressBar"
                                 Width="140"
                                 Height="8"
                                 Minimum="0"
                                 Maximum="100"
                                 Visibility="Collapsed"
                                 VerticalAlignment="Center"
                                 Margin="0,0,10,0"
                                 Foreground="{DynamicResource PrimaryBrush}"
                                 Background="{DynamicResource InputBrush}" />
                    <TextBlock x:Name="StatusText"
                               Text="Ready"
                               Foreground="{DynamicResource MutedTextBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                </StackPanel>
                <StackPanel>
                    <TextBlock x:Name="ScreenTitleText"
                               Text="GAMEVAULT"
                               FontSize="{DynamicResource AppScreenTitleFontSize}"
                               FontWeight="Bold"
                               FontFamily="Consolas, Cascadia Mono, Segoe UI" />
                    <TextBlock x:Name="ScreenSubtitleText"
                               Text="Desktop library"
                               Style="{StaticResource MutedText}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid x:Name="ScreensHost"
              Grid.Row="1"
              Margin="20">
            <Grid x:Name="StartScreen">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="420" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center"
                            Margin="36,0,36,0">
                    <TextBlock Text="RELIQUARY"
                               FontSize="{DynamicResource AppHeroFontSize}"
                               FontWeight="Black"
                               FontFamily="Consolas, Cascadia Mono, Segoe UI"
                               Foreground="{DynamicResource PrimaryBrush}" />
                    <TextBlock Text="Desktop collection control"
                               FontSize="{DynamicResource AppLargeFontSize}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Margin="4,8,0,36" />
                    <StackPanel HorizontalAlignment="Left">
                        <Button Content="New record"
                                Width="390"
                                Height="{DynamicResource AppStartButtonHeight}"
                                HorizontalAlignment="Left"
                                Click="NewGameButton_Click" />
                        <Button Content="Database"
                                Width="390"
                                Height="{DynamicResource AppStartButtonHeight}"
                                HorizontalAlignment="Left"
                                Click="OpenDatabaseButton_Click" />
                        <Button Content="Settings"
                                Width="390"
                                Height="{DynamicResource AppStartButtonHeight}"
                                HorizontalAlignment="Left"
                                Click="OpenSettingsButton_Click" />
                        <Button Content="Exit"
                                Width="390"
                                Height="{DynamicResource AppStartButtonHeight}"
                                HorizontalAlignment="Left"
                                Style="{StaticResource ExitButton}"
                                Click="ExitButton_Click" />
                    </StackPanel>
                </StackPanel>
                <Border Grid.Column="1"
                        Style="{StaticResource CyberPanel}"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Theme"
                                   Style="{StaticResource SectionTitle}" />
                        <ComboBox x:Name="StartThemeBox"
                                  DisplayMemberPath="Text"
                                  SelectedValuePath="Value"
                                  SelectionChanged="ThemeBox_SelectionChanged" />
                        <TextBlock Text="Use the same visual modes as the mobile GameVault shell."
                                   TextWrapping="Wrap"
                                   Style="{StaticResource MutedText}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid x:Name="MenuScreen"
                  Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <UniformGrid Columns="2"
                             Rows="2"
                             MaxWidth="920"
                             MaxHeight="520"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center">
                    <Button Content="New record"
                            Margin="12"
                            FontSize="{DynamicResource AppMenuButtonFontSize}"
                            Click="NewGameButton_Click" />
                    <Button Content="Database"
                            Margin="12"
                            FontSize="{DynamicResource AppMenuButtonFontSize}"
                            Click="OpenDatabaseButton_Click" />
                    <Button Content="Settings"
                            Margin="12"
                            FontSize="{DynamicResource AppMenuButtonFontSize}"
                            Click="OpenSettingsButton_Click" />
                    <Button Content="Exit"
                            Margin="12"
                            FontSize="{DynamicResource AppMenuButtonFontSize}"
                            Style="{StaticResource ExitButton}"
                            Click="ExitButton_Click" />
                </UniformGrid>
            </Grid>

            <Grid x:Name="DatabaseScreen"
                  Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Style="{StaticResource CyberPanel}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Margin="0,0,12,4"
                                   Text="Search by title"
                                   Style="{StaticResource LabelText}" />
                        <TextBox x:Name="SearchBox"
                                 Grid.Row="1"
                                 Grid.Column="0"
                                 Margin="0,0,12,0"
                                 Style="{StaticResource HeaderTextBox}"
                                 TextChanged="Filter_Changed"
                                 ToolTip="Search by title" />
                        <TextBlock Grid.Row="0"
                                   Grid.Column="1"
                                   Margin="0,0,12,4"
                                   Text="Statuses"
                                   Style="{StaticResource LabelText}" />
                        <ComboBox x:Name="StatusFilterBox"
                                  Grid.Row="1"
                                  Grid.Column="1"
                                  Margin="0,0,12,0"
                                  Style="{StaticResource HeaderComboBox}"
                                  SelectionChanged="Filter_Changed" />
                        <TextBlock Grid.Row="0"
                                   Grid.Column="2"
                                   Margin="0,0,12,4"
                                   Text="Sort"
                                   Style="{StaticResource LabelText}" />
                        <ComboBox x:Name="SortBox"
                                  Grid.Row="1"
                                  Grid.Column="2"
                                  Margin="0,0,12,0"
                                  Style="{StaticResource HeaderComboBox}"
                                  SelectionChanged="Filter_Changed" />
                        <StackPanel Grid.Column="3"
                                    Grid.Row="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Stretch">
                            <Button x:Name="ListModeButton"
                                    Content="List"
                                    Style="{StaticResource HeaderSecondaryButton}"
                                    Click="ListModeButton_Click" />
                            <Button x:Name="TilesModeButton"
                                    Content="Tiles"
                                    Style="{StaticResource HeaderSecondaryButton}"
                                    Click="TilesModeButton_Click" />
                            <Button Content="Import / Export"
                                    Style="{StaticResource HeaderSecondaryButton}"
                                    Click="OpenImportExportButton_Click" />
                            <Button Content="New"
                                    Margin="0"
                                    Style="{StaticResource HeaderButton}"
                                    Click="NewGameButton_Click" />
                        </StackPanel>
                    </Grid>
                </Border>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ListBox x:Name="GamesList"
                             Grid.Column="0"
                             ItemTemplate="{StaticResource GameCardTemplate}"
                             ItemsPanel="{StaticResource ListPanelTemplate}"
                             BorderThickness="0"
                             Padding="0,0,12,0"
                             SelectionChanged="GamesList_SelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
                    <Border Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Width="100"
                            Height="420"
                            Margin="0"
                            Padding="10"
                            Background="{DynamicResource PanelBrush}"
                            BorderBrush="{DynamicResource BorderBrushSoft}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Scale"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,8"
                                       FontSize="{DynamicResource AppCardScaleControlFontSize}"
                                       Style="{StaticResource MutedText}" />
                            <Button Grid.Row="1"
                                    Content="+"
                                    Width="48"
                                    Height="36"
                                    FontSize="{DynamicResource AppCardScaleControlFontSize}"
                                    Margin="0,0,0,10"
                                    Padding="0"
                                    HorizontalAlignment="Center"
                                    Click="IncreaseCardScaleButton_Click" />
                            <Slider x:Name="CardScaleSlider"
                                    Grid.Row="2"
                                    Width="48"
                                    HorizontalAlignment="Center"
                                    Style="{StaticResource CardScaleSliderStyle}"
                                    Minimum="0.75"
                                    Maximum="1.5"
                                    Value="1"
                                    TickFrequency="0.01"
                                    SmallChange="0.01"
                                    LargeChange="0.1"
                                    IsSnapToTickEnabled="True"
                                    Orientation="Vertical"
                                    ToolTip="Scale"
                                    ValueChanged="CardScaleSlider_ValueChanged" />
                            <TextBlock x:Name="CardScaleValueText"
                                       Grid.Row="3"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,8"
                                       FontSize="{DynamicResource AppCardScaleControlFontSize}"
                                       Foreground="{DynamicResource MutedTextBrush}" />
                            <Button Grid.Row="4"
                                    Content="-"
                                    Width="48"
                                    Height="36"
                                    FontSize="{DynamicResource AppCardScaleControlFontSize}"
                                    Margin="0"
                                    Padding="0"
                                    HorizontalAlignment="Center"
                                    Click="DecreaseCardScaleButton_Click" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Grid x:Name="AddModeScreen"
                  Visibility="Collapsed">
                <UniformGrid Columns="2"
                             MaxWidth="820"
                             MaxHeight="360"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center">
                    <Button Content="Manual add"
                            Margin="12"
                            FontSize="{DynamicResource AppMenuButtonFontSize}"
                            Click="ManualAddButton_Click" />
                    <Button Content="Add by link"
                            Margin="12"
                            FontSize="{DynamicResource AppMenuButtonFontSize}"
                            Style="{StaticResource SecondaryButton}"
                            Click="AutoAddModeButton_Click" />
                </UniformGrid>
            </Grid>

            <ScrollViewer x:Name="ManualEditScreen"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0"
                                Width="300"
                                HorizontalAlignment="Left"
                                Margin="0,0,18,0">
                        <Grid x:Name="CoverFrame"
                              Width="300"
                              Height="400"
                              Background="{DynamicResource SurfaceAltBrush}"
                              ClipToBounds="True"
                              Margin="0,0,0,12"
                              Cursor="Hand"
                              MouseLeftButtonDown="CoverFrame_MouseLeftButtonDown"
                              MouseMove="CoverFrame_MouseMove"
                              MouseLeftButtonUp="CoverFrame_MouseLeftButtonUp"
                              PreviewMouseWheel="CoverFrame_MouseWheel"
                              SizeChanged="CoverFrame_SizeChanged">
                            <Image x:Name="CoverPreview"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   RenderTransformOrigin="0.5,0.5"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Stretch="Fill" />
                            <Border x:Name="CoverEditHint"
                                    Panel.ZIndex="20"
                                    VerticalAlignment="Bottom"
                                    Margin="8"
                                    Background="#D0061019"
                                    BorderBrush="#AAFFFFFF"
                                    BorderThickness="1"
                                    Padding="9,7"
                                    IsHitTestVisible="False">
                                <TextBlock Text="Cover edit hint"
                                           FontSize="{DynamicResource AppLabelFontSize}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Foreground="White">
                                    <TextBlock.Effect>
                                        <DropShadowEffect BlurRadius="3"
                                                          Direction="270"
                                                          ShadowDepth="1"
                                                          Opacity="0.95"
                                                          Color="Black" />
                                    </TextBlock.Effect>
                                </TextBlock>
                            </Border>
                            <StackPanel x:Name="CoverEditActions"
                                        Panel.ZIndex="30"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="8"
                                        Visibility="Collapsed">
                                <Button Content="X"
                                        Width="34"
                                        Height="30"
                                        MinHeight="30"
                                        Padding="0"
                                        Margin="0,0,6,0"
                                        Style="{StaticResource DangerButton}"
                                        Click="CancelCoverEditButton_Click" />
                                <Button Content="OK"
                                        Width="34"
                                        Height="30"
                                        MinHeight="30"
                                        Padding="0"
                                        Margin="0"
                                        Click="ApplyCoverEditButton_Click" />
                            </StackPanel>
                            <Border BorderBrush="{DynamicResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    IsHitTestVisible="False" />
                        </Grid>
                        <Grid Width="{Binding ActualWidth, ElementName=CoverFrame}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Content="Add cover"
                                    Margin="0,0,10,10"
                                    Click="AddCoverLocalButton_Click" />
                            <Button Grid.Column="1"
                                    Content="Reload URL"
                                    Margin="0,0,0,10"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="ReloadCoverButton_Click" />
                        </Grid>
                        <TextBlock Text="Image URL"
                                   Style="{StaticResource LabelText}" />
                        <TextBox x:Name="CoverUrlBox"
                                 Width="{Binding ActualWidth, ElementName=CoverFrame}"
                                 ToolTip="Image URL" />
                        <Button Content="Download cover URL"
                                Width="{Binding ActualWidth, ElementName=CoverFrame}"
                                Margin="0,0,0,10"
                                Style="{StaticResource SecondaryButton}"
                                Click="DownloadCoverButton_Click" />
                        <Button Content="Save"
                                Width="{Binding ActualWidth, ElementName=CoverFrame}"
                                Margin="0,8,0,10"
                                Click="SaveGameButton_Click" />
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <Border Style="{StaticResource CyberPanel}">
                            <StackPanel>
                                <TextBlock Text="Main"
                                           Style="{StaticResource SectionTitle}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="130" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0"
                                                Margin="0,0,12,0">
                                        <TextBlock Text="Title"
                                                   Style="{StaticResource LabelText}" />
                                        <TextBox x:Name="TitleBox" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Year"
                                                   Style="{StaticResource LabelText}" />
                                        <TextBox x:Name="YearBox" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="Stable ID"
                                           Style="{StaticResource LabelText}" />
                                <TextBox x:Name="IdBox"
                                         IsReadOnly="True" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CyberPanel}">
                            <StackPanel>
                                <TextBlock Text="Platform / Distribution"
                                           Style="{StaticResource SectionTitle}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0"
                                                Margin="0,0,12,0">
                                        <TextBlock Text="Platform"
                                                   Style="{StaticResource LabelText}" />
                                        <ComboBox x:Name="PlatformBox"
                                                  SelectionChanged="PlatformBox_SelectionChanged" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1"
                                                Margin="0,0,12,0">
                                        <TextBlock Text="PC service"
                                                   Style="{StaticResource LabelText}" />
                                        <ComboBox x:Name="PcServiceBox"
                                                  DisplayMemberPath="Name"
                                                  SelectedValuePath="StableId" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Console model"
                                                   Style="{StaticResource LabelText}" />
                                        <ComboBox x:Name="ConsoleModelBox"
                                                  DisplayMemberPath="Name"
                                                  SelectedValuePath="StableId" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CyberPanel}">
                            <StackPanel>
                                <TextBlock Text="Statuses"
                                           Style="{StaticResource SectionTitle}" />
                                <UniformGrid Columns="3">
                                    <CheckBox x:Name="StatusCompletedBox"
                                              Content="COMPLETED" />
                                    <CheckBox x:Name="StatusInProgressBox"
                                              Content="IN_PROGRESS" />
                                    <CheckBox x:Name="StatusPostponedBox"
                                              Content="POSTPONED" />
                                    <CheckBox x:Name="StatusDroppedBox"
                                              Content="DROPPED" />
                                    <CheckBox x:Name="StatusPlannedBox"
                                              Content="PLANNED" />
                                    <CheckBox x:Name="StatusNeverPlayAgainBox"
                                              Content="NEVER_PLAY_AGAIN" />
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CyberPanel}">
                            <StackPanel>
                                <TextBlock Text="Images"
                                           Style="{StaticResource SectionTitle}" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Add local image"
                                            Click="AddGalleryLocalButton_Click" />
                                    <TextBox x:Name="GalleryUrlBox"
                                             Width="300"
                                             Margin="0,0,10,10"
                                             ToolTip="Gallery image URL" />
                                    <Button Content="Download URL"
                                            Click="AddGalleryUrlButton_Click" />
                                    <Button Content="Set as cover"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="SetGalleryCoverButton_Click" />
                                    <Button Content="Remove"
                                            Style="{StaticResource DangerButton}"
                                            Click="RemoveGalleryImageButton_Click" />
                                </StackPanel>
                                <ListBox x:Name="GalleryList"
                                         Height="250"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="150"
                                                    Height="210"
                                                    Padding="6"
                                                    Margin="0,0,10,10"
                                                    BorderBrush="{DynamicResource BorderBrushSoft}"
                                                    BorderThickness="1"
                                                    Background="{DynamicResource SurfaceAltBrush}">
                                                <StackPanel>
                                                    <Image Source="{Binding LocalPath}"
                                                           Height="158"
                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                           Stretch="UniformToFill" />
                                                    <TextBlock Text="{Binding ArchiveName}"
                                                               FontSize="{DynamicResource AppSmallFontSize}"
                                                               Margin="0,6,0,0"
                                                               Foreground="{DynamicResource MutedTextBrush}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CyberPanel}">
                            <StackPanel>
                                <TextBlock Text="Notes"
                                           Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="Source page URL"
                                           Style="{StaticResource LabelText}" />
                                <TextBox x:Name="SourcePageUrlBox" />
                                <TextBlock Text="Notes"
                                           Style="{StaticResource LabelText}" />
                                <TextBox x:Name="NotesBox"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="120"
                                         VerticalContentAlignment="Top"
                                         VerticalScrollBarVisibility="Auto" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Delete"
                                            Style="{StaticResource DangerButton}"
                                            Click="DeleteGameButton_Click" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <ScrollViewer x:Name="AutoAddScreen"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">
                <Border Style="{StaticResource CyberPanel}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Add by link"
                                   Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Store import"
                                   Style="{StaticResource LabelText}" />
                        <StackPanel>
                            <ComboBox x:Name="AutoAddSourceBox"
                                      Width="220"
                                      HorizontalAlignment="Left"
                                      Margin="0,4,0,12" />
                            <DockPanel LastChildFill="True">
                                <Button DockPanel.Dock="Right"
                                        Content="Import"
                                        Width="130"
                                        Margin="12,4,0,12"
                                        Click="AutoAddButton_Click" />
                                <TextBox x:Name="AutoAddReferenceBox"
                                         Margin="0,4,0,12"
                                         ToolTip="Steam AppID, store URL, or GOG/Epic slug" />
                            </DockPanel>
                        </StackPanel>
                        <TextBlock Text="Steam AppID, store URL, or GOG/Epic slug"
                                   Style="{StaticResource MutedText}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <Grid x:Name="DetailsScreen"
                  Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0"
                                Width="320"
                                HorizontalAlignment="Left"
                                Margin="0,0,18,0">
                        <Grid x:Name="DetailsCoverFrame"
                              Width="320"
                              Height="427"
                              Background="{DynamicResource SurfaceAltBrush}"
                              ClipToBounds="True"
                              Margin="0,0,0,14"
                              SizeChanged="CoverFrame_SizeChanged">
                            <Image x:Name="DetailsCoverPreview"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   RenderTransformOrigin="0.5,0.5"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Stretch="Fill" />
                            <Border BorderBrush="{DynamicResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    IsHitTestVisible="False" />
                        </Grid>
                        <Button Content="Edit"
                                Width="{Binding ActualWidth, ElementName=DetailsCoverFrame}"
                                Margin="0"
                                Click="EditCurrentGameButton_Click" />
                        <Button Content="Delete"
                                Width="{Binding ActualWidth, ElementName=DetailsCoverFrame}"
                                Margin="0,10,0,0"
                                Click="DeleteGameButton_Click" />
                    </StackPanel>
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Style="{StaticResource CyberPanel}">
                            <StackPanel>
                                <TextBlock x:Name="DetailTitleText"
                                           Text="Game"
                                           FontSize="{DynamicResource AppDetailTitleFontSize}"
                                           FontWeight="Black"
                                           FontFamily="Consolas, Cascadia Mono, Segoe UI"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="DetailSubtitleText"
                                           Style="{StaticResource MutedText}"
                                           FontSize="{DynamicResource AppLargeFontSize}"
                                           Margin="0,8,0,16"
                                           TextWrapping="Wrap" />
                                <WrapPanel>
                                    <Border Style="{StaticResource CyberChip}"
                                            Margin="0,0,10,10">
                                        <TextBlock x:Name="DetailStatusText"
                                                   Foreground="{DynamicResource PrimaryBrush}"
                                                   FontFamily="Consolas, Cascadia Mono, Segoe UI" />
                                    </Border>
                                    <Border Style="{StaticResource CyberChip}"
                                            Margin="0,0,10,10">
                                        <TextBlock x:Name="DetailYearText"
                                                   Foreground="{DynamicResource SecondaryBrush}"
                                                   FontFamily="Consolas, Cascadia Mono, Segoe UI" />
                                    </Border>
                                </WrapPanel>
                                <TextBlock x:Name="DetailSourceText"
                                           Style="{StaticResource MutedText}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1"
                                Style="{StaticResource CyberPanel}">
                            <StackPanel>
                                <TextBlock Text="Notes"
                                           Style="{StaticResource SectionTitle}" />
                                <TextBlock x:Name="DetailNotesText"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextBrush}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="2"
                                Style="{StaticResource CyberPanel}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Images"
                                           Style="{StaticResource SectionTitle}" />
                                <ListBox x:Name="DetailsGalleryList"
                                         Grid.Row="1"
                                         MinHeight="250"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="150"
                                                    Height="210"
                                                    Padding="6"
                                                    Margin="0,0,10,10"
                                                    BorderBrush="{DynamicResource BorderBrushSoft}"
                                                    BorderThickness="1"
                                                    Background="{DynamicResource SurfaceAltBrush}">
                                                <StackPanel>
                                                    <Image Source="{Binding LocalPath}"
                                                           Height="166"
                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                           Stretch="UniformToFill" />
                                                    <TextBlock Text="{Binding ArchiveName}"
                                                               FontSize="{DynamicResource AppSmallFontSize}"
                                                               Margin="0,6,0,0"
                                                               Foreground="{DynamicResource MutedTextBrush}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <ScrollViewer x:Name="ImportExportScreen"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource CyberPanel}">
                        <StackPanel>
                            <TextBlock Text="Local backup/export folder"
                                       Style="{StaticResource SectionTitle}" />
                            <DockPanel>
                                <TextBox x:Name="BackupFolderBox"
                                         DockPanel.Dock="Left"
                                         MinWidth="520"
                                         Margin="0,0,10,10" />
                                <Button Content="Choose folder"
                                        Click="ChooseBackupFolderButton_Click" />
                            </DockPanel>
                        </StackPanel>
                    </Border>
                    <UniformGrid Columns="2">
                        <Border Style="{StaticResource CyberPanel}"
                                Margin="0,0,8,16">
                            <StackPanel>
                                <TextBlock Text="Export"
                                           Style="{StaticResource SectionTitle}" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Export JSON"
                                            Click="ExportJsonButton_Click" />
                                    <Button Content="Export ZIP with images"
                                            Click="ExportZipButton_Click" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CyberPanel}"
                                Margin="8,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Import"
                                           Style="{StaticResource SectionTitle}" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Import JSON"
                                            Click="ImportJsonButton_Click" />
                                    <Button Content="Import ZIP"
                                            Click="ImportZipButton_Click" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                    <Border Style="{StaticResource CyberPanel}">
                        <StackPanel>
                            <TextBlock Text="Google Drive"
                                       Style="{StaticResource SectionTitle}" />
                            <WrapPanel>
                                <Button Content="Connect account"
                                        Click="ConnectDriveButton_Click" />
                                <Button Content="Disconnect"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="DisconnectDriveButton_Click" />
                                <Button Content="Upload ZIP backup"
                                        Click="UploadDriveBackupButton_Click" />
                                <Button Content="Auto export to Drive"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="AutoExportDriveBackupButton_Click" />
                                <Button Content="Refresh list"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="RefreshDriveBackupsButton_Click" />
                                <Button Content="Restore selected"
                                        Click="RestoreSelectedDriveBackupButton_Click" />
                                <Button Content="Restore latest"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="RestoreLatestDriveBackupButton_Click" />
                                <Button Content="Move to trash"
                                        Style="{StaticResource DangerButton}"
                                        Click="TrashDriveBackupButton_Click" />
                            </WrapPanel>
                            <DataGrid x:Name="DriveBackupsGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      MinHeight="260">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name"
                                                        Binding="{Binding Name}"
                                                        Width="*" />
                                    <DataGridTextColumn Header="Created"
                                                        Binding="{Binding CreatedText}"
                                                        Width="160" />
                                    <DataGridTextColumn Header="Size"
                                                        Binding="{Binding SizeText}"
                                                        Width="110" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock Text="Only the root /GameVault folder is used."
                                       Style="{StaticResource MutedText}"
                                       Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="SettingsScreen"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="1100"
                            HorizontalAlignment="Center">
                    <Border Style="{StaticResource CyberPanel}">
                        <StackPanel>
                            <TextBlock Text="Theme"
                                       Style="{StaticResource SectionTitle}" />
                            <ComboBox x:Name="ThemeBox"
                                      DisplayMemberPath="Text"
                                      SelectedValuePath="Value"
                                      SelectionChanged="ThemeBox_SelectionChanged" />
                            <Button Content="Theme editor"
                                    Style="{StaticResource SecondaryButton}"
                                    HorizontalAlignment="Left"
                                    Click="OpenThemeEditorButton_Click" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CyberPanel}">
                        <StackPanel>
                            <TextBlock Text="Language"
                                       Style="{StaticResource SectionTitle}" />
                            <ComboBox x:Name="LanguageBox"
                                      Width="260"
                                      HorizontalAlignment="Left"
                                      SelectionChanged="LanguageBox_SelectionChanged" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CyberPanel}">
                        <StackPanel>
                            <TextBlock Text="Font size"
                                       Style="{StaticResource SectionTitle}" />
                            <Grid Width="{DynamicResource AppFontScaleGridWidth}"
                                  HorizontalAlignment="Left">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Content="-"
                                        Width="{DynamicResource AppScaleStepButtonWidth}"
                                        Height="{DynamicResource AppHeaderControlHeight}"
                                        Margin="0,0,10,0"
                                        Padding="0"
                                        Click="DecreaseUiFontScaleButton_Click" />
                                <Slider x:Name="UiFontScaleSlider"
                                        Grid.Column="1"
                                        MinWidth="220"
                                        VerticalAlignment="Center"
                                        Minimum="0.8"
                                        Maximum="3"
                                        Value="1"
                                        TickFrequency="0.01"
                                        SmallChange="0.01"
                                        LargeChange="0.1"
                                        IsSnapToTickEnabled="True"
                                        ToolTip="Font size"
                                        ValueChanged="UiFontScaleSlider_ValueChanged" />
                                <Button Grid.Column="2"
                                        Content="+"
                                        Width="{DynamicResource AppScaleStepButtonWidth}"
                                        Height="{DynamicResource AppHeaderControlHeight}"
                                        Margin="10,0,0,0"
                                        Padding="0"
                                        Click="IncreaseUiFontScaleButton_Click" />
                                <TextBlock x:Name="UiFontScaleValueText"
                                           Grid.Column="3"
                                           MinWidth="{DynamicResource AppScaleValueColumnWidth}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Margin="14,0,0,0"
                                           Foreground="{DynamicResource MutedTextBrush}" />
                                <Button Grid.Column="4"
                                        Content="Reset"
                                        Height="{DynamicResource AppHeaderControlHeight}"
                                        Margin="10,0,0,0"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="ResetUiFontScaleButton_Click" />
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CyberPanel}">
                        <StackPanel>
                            <TextBlock Text="Feedback"
                                       Style="{StaticResource SectionTitle}" />
                            <CheckBox Content="Button sound" />
                            <CheckBox Content="Visual click feedback"
                                      IsChecked="True" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CyberPanel}">
                        <StackPanel>
                            <TextBlock Text="Maintenance"
                                       Style="{StaticResource SectionTitle}" />
                            <WrapPanel>
                                <Button Content="Import / Export"
                                        Click="OpenImportExportButton_Click" />
                                <Button Content="References"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="OpenReferencesButton_Click" />
                                <Button Content="Clear image cache"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="ClearImageCacheButton_Click" />
                                <Button Content="Clear library"
                                        Style="{StaticResource DangerButton}"
                                        Click="ClearLibraryButton_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="ThemeEditorScreen"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="900"
                            HorizontalAlignment="Center">
                    <Border Style="{StaticResource CyberPanel}">
                        <StackPanel>
                            <TextBlock Text="Built-in themes"
                                       Style="{StaticResource SectionTitle}" />
                            <ComboBox x:Name="ThemeEditorThemeBox"
                                      DisplayMemberPath="Text"
                                      SelectedValuePath="Value"
                                      SelectionChanged="ThemeEditorThemeBox_SelectionChanged" />
                            <WrapPanel>
                                <Button Content="Apply theme"
                                        HorizontalAlignment="Left"
                                        Click="ApplyThemeFromEditorButton_Click" />
                                <Button Content="New custom theme"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="NewCustomThemeButton_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CyberPanel}">
                        <StackPanel>
                            <TextBlock Text="Custom theme"
                                       Style="{StaticResource SectionTitle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0"
                                            Margin="0,0,12,0">
                                    <TextBlock Text="Name"
                                               Style="{StaticResource LabelText}" />
                                    <TextBox x:Name="CustomThemeNameBox" />
                                    <TextBlock Text="Background"
                                               Style="{StaticResource LabelText}" />
                                    <Grid Margin="0,4,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="CustomThemeBackgroundBox"
                                                 Margin="0"
                                                 TextChanged="CustomThemeColorBox_TextChanged" />
                                        <Button x:Name="CustomThemeBackgroundSwatch"
                                                Grid.Column="1"
                                                Style="{StaticResource ColorSwatchButton}"
                                                Tag="{Binding ElementName=CustomThemeBackgroundBox}"
                                                ToolTip="Choose color"
                                                Click="ColorSwatch_Click" />
                                    </Grid>
                                    <TextBlock Text="Surface"
                                               Style="{StaticResource LabelText}" />
                                    <Grid Margin="0,4,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="CustomThemeSurfaceBox"
                                                 Margin="0"
                                                 TextChanged="CustomThemeColorBox_TextChanged" />
                                        <Button x:Name="CustomThemeSurfaceSwatch"
                                                Grid.Column="1"
                                                Style="{StaticResource ColorSwatchButton}"
                                                Tag="{Binding ElementName=CustomThemeSurfaceBox}"
                                                ToolTip="Choose color"
                                                Click="ColorSwatch_Click" />
                                    </Grid>
                                    <TextBlock Text="Panel"
                                               Style="{StaticResource LabelText}" />
                                    <Grid Margin="0,4,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="CustomThemePanelBox"
                                                 Margin="0"
                                                 TextChanged="CustomThemeColorBox_TextChanged" />
                                        <Button x:Name="CustomThemePanelSwatch"
                                                Grid.Column="1"
                                                Style="{StaticResource ColorSwatchButton}"
                                                Tag="{Binding ElementName=CustomThemePanelBox}"
                                                ToolTip="Choose color"
                                                Click="ColorSwatch_Click" />
                                    </Grid>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Text"
                                               Style="{StaticResource LabelText}" />
                                    <Grid Margin="0,4,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="CustomThemeTextBox"
                                                 Margin="0"
                                                 TextChanged="CustomThemeColorBox_TextChanged" />
                                        <Button x:Name="CustomThemeTextSwatch"
                                                Grid.Column="1"
                                                Style="{StaticResource ColorSwatchButton}"
                                                Tag="{Binding ElementName=CustomThemeTextBox}"
                                                ToolTip="Choose color"
                                                Click="ColorSwatch_Click" />
                                    </Grid>
                                    <TextBlock Text="Muted text"
                                               Style="{StaticResource LabelText}" />
                                    <Grid Margin="0,4,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="CustomThemeMutedBox"
                                                 Margin="0"
                                                 TextChanged="CustomThemeColorBox_TextChanged" />
                                        <Button x:Name="CustomThemeMutedSwatch"
                                                Grid.Column="1"
                                                Style="{StaticResource ColorSwatchButton}"
                                                Tag="{Binding ElementName=CustomThemeMutedBox}"
                                                ToolTip="Choose color"
                                                Click="ColorSwatch_Click" />
                                    </Grid>
                                    <TextBlock Text="Primary"
                                               Style="{StaticResource LabelText}" />
                                    <Grid Margin="0,4,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="CustomThemePrimaryBox"
                                                 Margin="0"
                                                 TextChanged="CustomThemeColorBox_TextChanged" />
                                        <Button x:Name="CustomThemePrimarySwatch"
                                                Grid.Column="1"
                                                Style="{StaticResource ColorSwatchButton}"
                                                Tag="{Binding ElementName=CustomThemePrimaryBox}"
                                                ToolTip="Choose color"
                                                Click="ColorSwatch_Click" />
                                    </Grid>
                                    <TextBlock Text="Secondary"
                                               Style="{StaticResource LabelText}" />
                                    <Grid Margin="0,4,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="CustomThemeSecondaryBox"
                                                 Margin="0"
                                                 TextChanged="CustomThemeColorBox_TextChanged" />
                                        <Button x:Name="CustomThemeSecondarySwatch"
                                                Grid.Column="1"
                                                Style="{StaticResource ColorSwatchButton}"
                                                Tag="{Binding ElementName=CustomThemeSecondaryBox}"
                                                ToolTip="Choose color"
                                                Click="ColorSwatch_Click" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                            <WrapPanel>
                                <Button Content="Save custom theme"
                                        Click="SaveCustomThemeButton_Click" />
                                <Button Content="Delete custom theme"
                                        Style="{StaticResource DangerButton}"
                                        Click="DeleteCustomThemeButton_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="ReferencesScreen"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource CyberPanel}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top"
                                        Orientation="Horizontal">
                                <TextBox x:Name="NewPcServiceBox"
                                         Width="300"
                                         Margin="0,0,10,10" />
                                <Button Content="Add service"
                                        Click="AddPcServiceButton_Click" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="PC services"
                                           Style="{StaticResource SectionTitle}" />
                                <ListBox x:Name="PcServicesList"
                                         DisplayMemberPath="Name"
                                         MinHeight="130" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <Border Style="{StaticResource CyberPanel}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top"
                                        Orientation="Horizontal">
                                <TextBox x:Name="NewConsoleFamilyBox"
                                         Width="300"
                                         Margin="0,0,10,10" />
                                <Button Content="Add family"
                                        Click="AddConsoleFamilyButton_Click" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Console families"
                                           Style="{StaticResource SectionTitle}" />
                                <ListBox x:Name="ConsoleFamiliesList"
                                         DisplayMemberPath="Name"
                                         MinHeight="130" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <Border Style="{StaticResource CyberPanel}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top"
                                        Orientation="Horizontal">
                                <ComboBox x:Name="NewModelFamilyBox"
                                          Width="220"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="StableId"
                                          Margin="0,4,10,10" />
                                <TextBox x:Name="NewConsoleModelBox"
                                         Width="300"
                                         Margin="0,0,10,10" />
                                <Button Content="Add model"
                                        Click="AddConsoleModelButton_Click" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Console models"
                                           Style="{StaticResource SectionTitle}" />
                                <ListBox x:Name="ConsoleModelsList"
                                         DisplayMemberPath="Name"
                                         MinHeight="170" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Popup x:Name="ColorPickerPopup"
                   Placement="Bottom"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrushSoft}"
                        BorderThickness="1"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="276" />
                            <ColumnDefinition Width="34" />
                            <ColumnDefinition Width="44" />
                        </Grid.ColumnDefinitions>
                        <Canvas Width="276"
                                Height="234">
                            <Image x:Name="SaturationValueImage"
                                   Width="276"
                                   Height="234"
                                   Stretch="Fill"
                                   MouseDown="SaturationValueImage_MouseDown"
                                   MouseMove="SaturationValueImage_MouseMove"
                                   MouseUp="ColorPickerImage_MouseUp" />
                            <Ellipse x:Name="SaturationValueMarker"
                                     Width="10"
                                     Height="10"
                                     Stroke="White"
                                     StrokeThickness="1"
                                     Fill="Transparent"
                                     IsHitTestVisible="False">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="2"
                                                      ShadowDepth="0"
                                                      Color="Black" />
                                </Ellipse.Effect>
                            </Ellipse>
                        </Canvas>
                        <Canvas Grid.Column="1"
                                Width="34"
                                Height="234"
                                Margin="8,0,0,0">
                            <Image x:Name="HueImage"
                                   Width="34"
                                   Height="234"
                                   Stretch="Fill"
                                   MouseDown="HueImage_MouseDown"
                                   MouseMove="HueImage_MouseMove"
                                   MouseUp="ColorPickerImage_MouseUp" />
                            <Rectangle x:Name="HueMarker"
                                       Width="38"
                                       Height="4"
                                       Stroke="Black"
                                       StrokeThickness="1"
                                       Fill="Transparent"
                                       IsHitTestVisible="False" />
                        </Canvas>
                        <Border x:Name="PickerPreview"
                                Grid.Column="2"
                                Width="34"
                                Height="34"
                                Margin="10,0,0,0"
                                BorderBrush="{DynamicResource BorderBrushSoft}"
                                BorderThickness="1" />

                        <TextBlock Grid.Row="1"
                                   Text="R"
                                   Style="{StaticResource LabelText}"
                                   VerticalAlignment="Center"
                                   Margin="6,12,10,0" />
                        <Slider x:Name="RedSlider"
                                Grid.Row="1"
                                Grid.Column="0"
                                Minimum="0"
                                Maximum="255"
                                Margin="30,12,0,0"
                                ValueChanged="RgbSlider_ValueChanged" />
                        <TextBlock x:Name="RedValueText"
                                   Grid.Row="1"
                                   Grid.Column="2"
                                   Style="{StaticResource LabelText}"
                                   Margin="10,12,0,0"
                                   VerticalAlignment="Center" />

                        <TextBlock Grid.Row="2"
                                   Text="G"
                                   Style="{StaticResource LabelText}"
                                   VerticalAlignment="Center"
                                   Margin="6,6,10,0" />
                        <Slider x:Name="GreenSlider"
                                Grid.Row="2"
                                Grid.Column="0"
                                Minimum="0"
                                Maximum="255"
                                Margin="30,6,0,0"
                                ValueChanged="RgbSlider_ValueChanged" />
                        <TextBlock x:Name="GreenValueText"
                                   Grid.Row="2"
                                   Grid.Column="2"
                                   Style="{StaticResource LabelText}"
                                   Margin="10,6,0,0"
                                   VerticalAlignment="Center" />

                        <TextBlock Grid.Row="3"
                                   Text="B"
                                   Style="{StaticResource LabelText}"
                                   VerticalAlignment="Center"
                                   Margin="6,6,10,0" />
                        <Slider x:Name="BlueSlider"
                                Grid.Row="3"
                                Grid.Column="0"
                                Minimum="0"
                                Maximum="255"
                                Margin="30,6,0,0"
                                ValueChanged="RgbSlider_ValueChanged" />
                        <TextBlock x:Name="BlueValueText"
                                   Grid.Row="3"
                                   Grid.Column="2"
                                   Style="{StaticResource LabelText}"
                                   Margin="10,6,0,0"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </Popup>
        </Grid>
    </Grid>
</Window>
